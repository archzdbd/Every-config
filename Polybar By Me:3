[colors]
background = #00000000
foreground = #ffffff

[bar/main]
width = 100%
height = 24
background = ${colors.background}
foreground = ${colors.foreground}
font-0 = "Terminus:size=12;2"
font-1 = "Symbols Nerd Font:size=12;2"
modules-left = i3 xwindow
modules-center =
modules-right = disk memory cpu-temp gpu-temp volume time

[module/i3]
type = internal/i3
format = <label-state> <label-mode>
index-sort = true
wrapping-scroll = false
label-focused = %index%
label-focused-padding = 2
label-focused-foreground = #ffffff
label-unfocused = %index%
label-unfocused-padding = 2
label-unfocused-foreground = #888888
label-urgent = %index%
label-urgent-background = #A54242
label-urgent-padding = 2

[module/xwindow]
type = internal/xwindow
label = %title:0:50:...%
label-padding = 2
label-foreground = #aaaaaa

[module/disk]
type = internal/fs
interval = 30
mount-0 = /
label-mounted = / %percentage_used%%
label-mounted-padding = 2
label-mounted-foreground = #ffffff

[module/memory]
type = internal/memory
interval = 2
label = RAM %percentage_used%%
label-padding = 2

[module/cpu-temp]
type = custom/script
exec = sensors | grep 'Tctl' | awk '{print "CPU " $2}'
interval = 3
label-padding = 2

[module/gpu-temp]
type = custom/script
exec = nvidia-smi --query-gpu=temperature.gpu --format=csv,noheader,nounits | awk '{print "GPU " $1 "°C"}'
interval = 3
label-padding = 2

[module/volume]
type = internal/pulseaudio
format-volume = 󰕾 <label-volume>
label-volume = %percentage%%
label-volume-padding = 2
format-muted = 󰝟 <label-muted>
label-muted = muted
label-muted-padding = 2
label-muted-foreground = #888888

[module/time]
type = internal/date
interval = 1
date = %H:%M
label = %date%
label-padding = 2

[settings]
screenchange-reload = true
pseudo-transparency = true
